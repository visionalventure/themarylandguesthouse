NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://mgh_user:mgh_dev_pass@localhost:5432/maryland_guesthouse_dev"
REDIS_URL="redis://localhost:6379"
JWT_SECRET=dev-jwt-secret-change-in-production-minimum-64-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-minimum-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 File Storage
# 1. Create a bucket at dash.cloudflare.com → R2 → Create bucket
# 2. Enable public access on the bucket and copy the r2.dev URL
# 3. Create an API token with Object Read & Write permissions
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET=mgh-erp
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
