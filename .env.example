# ============================================================
# MARYLAND GUESTHOUSE ERP - Environment Configuration
# Copy this file to .env and fill in all values
# ============================================================

# Database
DATABASE_URL="postgresql://mgh_user:your_secure_password@localhost:5432/maryland_guesthouse"
POSTGRES_USER=mgh_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=maryland_guesthouse

# Redis
REDIS_URL="redis://:your_redis_password@localhost:6379"
REDIS_PASSWORD=your_redis_password

# JWT Secrets — Generate with: openssl rand -hex 64
JWT_SECRET=your_very_long_random_jwt_secret_at_least_64_characters
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_at_least_64_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# File Storage (choose one: AWS S3 or Cloudflare R2)
STORAGE_PROVIDER=s3  # s3 | r2 | local

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=maryland-guesthouse-erp

# Cloudflare R2 (alternative to S3)
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET=maryland-guesthouse-erp

# Payment Gateways
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# Mobile Money (Liberia)
ORANGE_MONEY_API_KEY=your_orange_money_key
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/lr/v1
MTN_MOMO_API_KEY=your_mtn_momo_key
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com

# Email (SendGrid / SMTP)
EMAIL_PROVIDER=sendgrid  # sendgrid | smtp
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@marylandguesthouse.com
EMAIL_FROM_NAME="Maryland Guesthouse ERP"

# WhatsApp (Twilio / WhatsApp Business API)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Metabase (Analytics)
METABASE_URL=http://localhost:3003
METABASE_SECRET_KEY=your_metabase_secret_key

# Default Tenant / Property Setup
DEFAULT_TENANT_SLUG=maryland-guesthouse
DEFAULT_PROPERTY_CODE=MGH-001
ADMIN_EMAIL=admin@marylandguesthouse.com
ADMIN_PASSWORD=ChangeMe@FirstLogin!

# Monitoring
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
