// Maryland Guesthouse ERP - Comprehensive Prisma Schema
// Version: 1.0.0

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  FRONT_DESK
  ACCOUNTANT
  HOUSEKEEPING
  MAINTENANCE
  RESTAURANT_STAFF
  HR_MANAGER
  PROCUREMENT_OFFICER
  GUEST
}

enum PropertyType {
  GUESTHOUSE
  HOTEL
  LODGE
  RESORT
  APARTMENT
}

enum RoomStatus {
  AVAILABLE     // Vacant Clean — ready for guest
  VACANT_DIRTY  // Post-checkout, awaiting housekeeping
  OCCUPIED      // Guest in room
  RESERVED      // Confirmed future booking
  CLEANING      // Housekeeping in progress
  MAINTENANCE   // Under repair
  OUT_OF_ORDER  // Out of service
  BLOCKED       // Manually blocked
}

enum GuestPrivacyType {
  STANDARD
  PRIVATE
  VIP
  CONFIDENTIAL
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  TRIPLE
  SUITE
  EXECUTIVE_SUITE
  PRESIDENTIAL_SUITE
  FAMILY_ROOM
  CONFERENCE_ROOM
}

enum ReservationStatus {
  PENDING
  RESERVED
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
  WAITLISTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  VISA
  MASTERCARD
  PAYPAL
  STRIPE
  ORANGE_MONEY
  MTN_MOBILE_MONEY
  BANK_TRANSFER
  CHECK
  LOYALTY_POINTS
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  VOID
}

enum BillStatus {
  DRAFT
  APPROVED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  SUSPENDED
  RESIGNED
  RETIRED
  PROBATION
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  COMPASSIONATE
  STUDY
  CASUAL
  EMERGENCY
  SUSPENSION
}

enum DisciplinaryActionType {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WRITTEN_WARNING
  FINANCIAL_RECOVERY
  SUSPENSION_WITH_PAY
  SUSPENSION_WITHOUT_PAY
  DEMOTION
  LOSS_OF_PRIVILEGE
  PIP
  TRANSFER
  TERMINATION_RECOMMENDATION
}

enum DisciplinaryCaseStatus {
  REPORTED
  UNDER_REVIEW
  INVESTIGATING
  EMPLOYEE_NOTIFIED
  HEARING_SCHEDULED
  DECISION_PENDING
  APPROVED
  REJECTED
  APPEALED
  CLOSED
}

enum SuspensionType {
  WITH_PAY
  WITHOUT_PAY
  INVESTIGATIVE
  ADMIN_LEAVE
  TEMP_DUTY_REMOVAL
}

enum GrievanceStatus {
  SUBMITTED
  UNDER_REVIEW
  INVESTIGATION
  MEDIATION
  RESOLVED
  ESCALATED
  CLOSED
}

enum GrievanceType {
  HARASSMENT
  SALARY_DISPUTE
  SUPERVISOR_COMPLAINT
  UNSAFE_CONDITIONS
  DISCRIMINATION
  UNFAIR_TREATMENT
  WORKLOAD
  SHIFT_ROSTER
  OTHER
}

enum StaffLoanStatus {
  PENDING
  APPROVED
  ACTIVE
  SETTLED
  REJECTED
  CANCELLED
}

enum CandidateStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFER_EXTENDED
  HIRED
  REJECTED
  WITHDRAWN
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum AttendanceAnomalyType {
  REPEATED_LATENESS
  NO_CLOCK_OUT
  EARLY_DEPARTURE
  UNAUTHORIZED_ABSENCE
  EXCESSIVE_OVERTIME
  MISSED_SHIFT
  SUSPICIOUS_EDIT
  ROSTER_CONFLICT
  HALF_DAY_PATTERN
}

enum DeductionCategory {
  DAMAGE_RECOVERY
  UNAUTHORIZED_ABSENCE
  CASH_SHORTAGE
  TILL_VARIANCE
  SALARY_ADVANCE
  LOAN_RECOVERY
  ASSET_LOSS
  DISCIPLINARY_FINE
  UNIFORM_RECOVERY
  DEVICE_RECOVERY
  OTHER
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  SPLIT
  OFF_DAY
  ON_CALL
}

enum SeparationType {
  RESIGNATION
  TERMINATION
  END_OF_CONTRACT
  RETIREMENT
  DISMISSAL
  ABSCONDED
  REDUNDANCY
}

enum ProbationOutcome {
  CONFIRMED
  EXTENDED
  TERMINATED
  PENDING
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProcurementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
  VOID
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  VIP
}

enum DocumentCategory {
  CONTRACT
  LICENSE
  STAFF_FILE
  PROCUREMENT
  FINANCIAL
  LEGAL
  INSURANCE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  VOID
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================================
// MULTI-TENANT: TENANTS / PROPERTIES
// ============================================================

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  website     String?
  email       String
  phone       String?
  address     String?
  city        String?
  country     String       @default("Liberia")
  currency    String       @default("USD")
  timezone    String       @default("Africa/Monrovia")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  properties  Property[]
  users       User[]
  subscription Subscription?

  @@map("tenants")
}

model Subscription {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  plan        String    @default("starter")
  status      String    @default("active")
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model Property {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  code         String
  type         PropertyType @default(GUESTHOUSE)
  description  String?
  address      String?
  city         String?
  country      String       @default("Liberia")
  phone        String?
  email        String?
  starRating   Int?
  checkInTime  String       @default("14:00")
  checkOutTime String       @default("12:00")
  logoUrl         String?
  coverImageUrl   String?
  currency        String       @default("USD")
  timezone        String       @default("Africa/Monrovia")
  invoiceTemplate Json?
  policyConfig    Json?
  isActive        Boolean      @default(true)
  // Privacy & Identification Policy
  requireIdentification Boolean @default(true)
  requireAddress        Boolean @default(false)
  requirePhone          Boolean @default(false)
  allowAnonymousWalkIn  Boolean @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  rooms        Room[]
  reservations Reservation[]
  inventory    InventoryItem[]
  employees    Employee[]
  maintenanceAssets Asset[]
  accounts     Account[]
  bankAccounts BankAccount[]
  budgets      Budget[]
  documents    Document[]
  documentCustomCategories DocumentCustomCategory[]
  restaurants  Restaurant[]
  housekeepingTasks HousekeepingTask[]
  purchaseOrders PurchaseOrder[]
  nightAudits   NightAudit[]
  shiftTypeConfigs ShiftTypeConfig[]

  @@unique([tenantId, code])
  @@map("properties")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id                String    @id @default(cuid())
  tenantId          String
  email             String
  passwordHash      String
  firstName         String
  lastName          String
  phone             String?
  avatarUrl         String?
  role              UserRole  @default(FRONT_DESK)
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs         AuditLog[]
  employee          Employee?
  createdReservations Reservation[] @relation("CreatedBy")
  assignedHousekeeping HousekeepingTask[] @relation("AssignedTo")
  createdJournalEntries JournalEntry[] @relation("JournalCreatedBy")
  approvedPurchaseOrders PurchaseOrder[] @relation("POApprovedBy")

  @@unique([tenantId, email])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  isRevoked   Boolean   @default(false)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ============================================================
// GUEST CRM
// ============================================================

model Guest {
  id              String    @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  nationalId      String?
  passportNumber  String?
  passportExpiry  DateTime?
  nationality     String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  city            String?
  country         String?
  company         String?
  jobTitle        String?
  dietaryPrefs    String?
  roomPreferences String?
  notes           String?
  blacklisted     Boolean          @default(false)
  blacklistReason String?
  privacyType     GuestPrivacyType @default(STANDARD)
  alias           String?
  totalStays      Int              @default(0)
  totalSpent      Decimal          @default(0) @db.Decimal(12,2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  reservations    Reservation[]
  loyaltyAccount  LoyaltyAccount?
  invoices        Invoice[]
  privacyLogs     GuestPrivacyLog[]

  @@unique([tenantId, email])
  @@map("guests")
}

// ============================================================
// LOYALTY PROGRAM
// ============================================================

model LoyaltyAccount {
  id              String      @id @default(cuid())
  guestId         String      @unique
  tier            LoyaltyTier @default(BRONZE)
  points          Int         @default(0)
  lifetimePoints  Int         @default(0)
  memberNumber    String      @unique
  memberSince     DateTime    @default(now())
  tierExpiresAt   DateTime?
  updatedAt       DateTime    @updatedAt

  guest           Guest       @relation(fields: [guestId], references: [id])
  transactions    LoyaltyTransaction[]
  redemptions     LoyaltyRedemption[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id              String   @id @default(cuid())
  loyaltyAccountId String
  points          Int
  type            String   // EARN | REDEEM | EXPIRE | ADJUST | BONUS
  description     String
  referenceId     String?
  referenceType   String?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  account         LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id])

  @@map("loyalty_transactions")
}

model LoyaltyRedemption {
  id               String   @id @default(cuid())
  loyaltyAccountId String
  rewardType       String   // DISCOUNT | ROOM_UPGRADE | FREE_NIGHT | F&B_CREDIT
  pointsUsed       Int
  valueAmount      Decimal  @db.Decimal(10,2)
  reservationId    String?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  account          LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id])

  @@map("loyalty_redemptions")
}

model LoyaltyRule {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String   // STAY | SPEND | REFERRAL | BIRTHDAY | SIGNUP
  pointsValue Int
  minSpend    Decimal? @db.Decimal(10,2)
  multiplier  Decimal  @default(1) @db.Decimal(5,2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("loyalty_rules")
}

// ============================================================
// ROOMS
// ============================================================

model RoomCategory {
  id           String   @id @default(cuid())
  propertyId   String
  name         String
  type         RoomType
  description  String?
  basePrice    Decimal  @db.Decimal(10,2)
  maxOccupancy Int
  bedCount     Int      @default(1)
  amenities    String[] @default([])
  images       String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooms        Room[]

  @@map("room_categories")
}

model Room {
  id            String     @id @default(cuid())
  propertyId    String
  categoryId    String
  roomNumber    String
  floor         Int?
  status        RoomStatus @default(AVAILABLE)
  isActive      Boolean    @default(true)
  notes         String?
  lastCleaned   DateTime?
  lastInspected DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id])
  category      RoomCategory  @relation(fields: [categoryId], references: [id])
  reservations  ReservationRoom[]
  housekeepingTasks HousekeepingTask[]
  maintenanceWorkOrders WorkOrder[]
  roomPricing   RoomPricing[]

  @@unique([propertyId, roomNumber])
  @@map("rooms")
}

model RoomPricing {
  id          String   @id @default(cuid())
  roomId      String
  name        String
  pricePerNight Decimal @db.Decimal(10,2)
  startDate   DateTime?
  endDate     DateTime?
  isDefault   Boolean  @default(false)
  minNights   Int      @default(1)
  createdAt   DateTime @default(now())

  room        Room     @relation(fields: [roomId], references: [id])

  @@map("room_pricing")
}

model RoomAmenity {
  id          String  @id @default(cuid())
  name        String
  icon        String?
  category    String?

  @@map("room_amenities")
}

// ============================================================
// RESERVATIONS
// ============================================================

model Reservation {
  id              String            @id @default(cuid())
  propertyId      String
  guestId         String
  createdById     String?
  reservationNo   String            @unique
  status          ReservationStatus @default(PENDING)
  checkIn         DateTime
  checkOut        DateTime
  adults          Int               @default(1)
  children        Int               @default(0)
  source          String?           // DIRECT | OTA | WALK_IN | CORPORATE | ONLINE
  channelId       String?
  corporateId     String?
  groupId         String?
  specialRequests String?
  arrivalTime     String?
  depositAmount   Decimal           @default(0) @db.Decimal(10,2)
  depositPaid     Boolean           @default(false)
  totalAmount     Decimal           @db.Decimal(12,2)
  discountAmount  Decimal           @default(0) @db.Decimal(10,2)
  taxAmount       Decimal           @default(0) @db.Decimal(10,2)
  couponCode      String?
  notes           String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  noShowAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  property        Property          @relation(fields: [propertyId], references: [id])
  guest           Guest             @relation(fields: [guestId], references: [id])
  createdBy       User?             @relation("CreatedBy", fields: [createdById], references: [id])
  holdExpiresAt   DateTime?

  rooms           ReservationRoom[]
  payments        Payment[]
  invoices        Invoice[]
  charges         ReservationCharge[]
  corporateAccount CorporateAccount? @relation(fields: [corporateId], references: [id])
  group           GroupBooking?     @relation(fields: [groupId], references: [id])

  @@map("reservations")
}

model ReservationRoom {
  id            String      @id @default(cuid())
  reservationId String
  roomId        String
  ratePerNight  Decimal     @db.Decimal(10,2)
  totalNights   Int
  totalAmount   Decimal     @db.Decimal(12,2)

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  room          Room        @relation(fields: [roomId], references: [id])

  @@unique([reservationId, roomId])
  @@map("reservation_rooms")
}

model ReservationCharge {
  id            String      @id @default(cuid())
  reservationId String
  description   String
  amount        Decimal     @db.Decimal(10,2)
  chargeType    String      // ROOM | F&B | MINIBAR | LAUNDRY | SPA | TELEPHONE | OTHER
  quantity      Int         @default(1)
  unitPrice     Decimal     @db.Decimal(10,2)
  taxRate       Decimal     @default(0) @db.Decimal(5,2)
  orderId       String?
  createdAt     DateTime    @default(now())

  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@map("reservation_charges")
}

model GroupBooking {
  id            String   @id @default(cuid())
  tenantId      String
  groupName     String
  contactName   String
  contactEmail  String?
  contactPhone  String?
  totalRooms    Int
  notes         String?
  createdAt     DateTime @default(now())

  reservations  Reservation[]

  @@map("group_bookings")
}

model CorporateAccount {
  id              String   @id @default(cuid())
  tenantId        String
  companyName     String
  contactName     String
  contactEmail    String?
  contactPhone    String?
  address         String?
  discountRate    Decimal  @default(0) @db.Decimal(5,2)
  creditLimit     Decimal  @default(0) @db.Decimal(12,2)
  paymentTermDays Int      @default(30)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  reservations    Reservation[]
  invoices        Invoice[]

  @@map("corporate_accounts")
}

model Coupon {
  id            String    @id @default(cuid())
  tenantId      String
  code          String    @unique
  description   String?
  discountType  String    // PERCENTAGE | FIXED
  discountValue Decimal   @db.Decimal(10,2)
  minStay       Int?
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@map("coupons")
}

// ============================================================
// PAYMENTS & INVOICING
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  tenantId        String
  reservationId   String?
  invoiceId       String?
  guestId         String?
  amount          Decimal       @db.Decimal(12,2)
  currency        String        @default("USD")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  gatewayResponse Json?
  receiptUrl      String?
  receiptNumber   String?       @unique  // RCP-YYYY-XXXXXX
  notes           String?
  processedAt     DateTime?
  refundedAt      DateTime?
  refundAmount    Decimal?      @db.Decimal(12,2)
  refundReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservation     Reservation?  @relation(fields: [reservationId], references: [id])
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  invoiceNumber   String        @unique
  propertyId      String?
  guestId         String?
  corporateId     String?
  reservationId   String?
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  subtotal        Decimal       @db.Decimal(12,2)
  taxAmount       Decimal       @default(0) @db.Decimal(12,2)
  discountAmount  Decimal       @default(0) @db.Decimal(12,2)
  totalAmount     Decimal       @db.Decimal(12,2)
  paidAmount      Decimal       @default(0) @db.Decimal(12,2)
  notes           String?
  terms           String?
  pdfUrl          String?
  sentAt          DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  guest           Guest?        @relation(fields: [guestId], references: [id])
  corporate       CorporateAccount? @relation(fields: [corporateId], references: [id])
  reservation     Reservation?  @relation(fields: [reservationId], references: [id])
  lineItems       InvoiceLineItem[]
  payments        Payment[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10,3)
  unitPrice   Decimal  @db.Decimal(10,2)
  taxRate     Decimal  @default(0) @db.Decimal(5,2)
  total       Decimal  @db.Decimal(12,2)
  accountId   String?

  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  @@map("invoice_line_items")
}

// ============================================================
// HOUSEKEEPING
// ============================================================

model HousekeepingTask {
  id            String     @id @default(cuid())
  propertyId    String
  roomId        String
  assignedToId  String?
  taskType      String     // CHECKOUT_CLEAN | STAYOVER_CLEAN | DEEP_CLEAN | INSPECTION | TURNDOWN
  status        TaskStatus @default(PENDING)
  priority      String     @default("NORMAL")
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  checklistData Json?
  inspectedBy   String?
  inspectionNotes String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property      Property   @relation(fields: [propertyId], references: [id])
  room          Room       @relation(fields: [roomId], references: [id])
  assignedTo    User?      @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@map("housekeeping_tasks")
}

model HousekeepingChecklist {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  taskType    String
  items       Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("housekeeping_checklists")
}

// ============================================================
// RESTAURANT & BAR POS
// ============================================================

model Restaurant {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  type        String   @default("RESTAURANT") // RESTAURANT | BAR | CAFE | POOL_BAR
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id])
  tables      RestaurantTable[]
  menuItems   MenuItem[]
  orders      RestaurantOrder[]

  @@map("restaurants")
}

model RestaurantTable {
  id           String     @id @default(cuid())
  restaurantId String
  tableNumber  String
  capacity     Int
  status       String     @default("AVAILABLE") // AVAILABLE | OCCUPIED | RESERVED
  location     String?
  createdAt    DateTime   @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       RestaurantOrder[]

  @@unique([restaurantId, tableNumber])
  @@map("restaurant_tables")
}

model MenuCategory {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  items       MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String       @id @default(cuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Decimal      @db.Decimal(10,2)
  costPrice    Decimal?     @db.Decimal(10,2)
  imageUrl     String?
  isAvailable  Boolean      @default(true)
  preparationTime Int?
  allergens    String[]     @default([])
  isVegetarian Boolean      @default(false)
  isVegan      Boolean      @default(false)
  createdAt    DateTime     @default(now())

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  category     MenuCategory? @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]

  @@map("menu_items")
}

model RestaurantOrder {
  id            String       @id @default(cuid())
  restaurantId  String
  tableId       String?
  reservationId String?
  guestName     String?
  roomNumber    String?
  orderNumber   String       @unique
  status        OrderStatus  @default(PENDING)
  orderType     String       @default("DINE_IN") // DINE_IN | ROOM_SERVICE | TAKEAWAY | BAR
  subtotal      Decimal      @db.Decimal(10,2)
  taxAmount     Decimal      @default(0) @db.Decimal(10,2)
  totalAmount   Decimal      @db.Decimal(10,2)
  chargeToRoom  Boolean      @default(false)
  notes         String?
  preparedAt    DateTime?
  servedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id])
  table         RestaurantTable? @relation(fields: [tableId], references: [id])
  items         OrderItem[]

  @@map("restaurant_orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  menuItemId  String
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10,2)
  totalPrice  Decimal         @db.Decimal(10,2)
  notes       String?
  status      String          @default("PENDING")

  order       RestaurantOrder @relation(fields: [orderId], references: [id])
  menuItem    MenuItem        @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// ============================================================
// INVENTORY MANAGEMENT
// ============================================================

model InventoryCategory {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?

  parent      InventoryCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    InventoryCategory[] @relation("CategoryHierarchy")
  items       InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id              String    @id @default(cuid())
  propertyId      String
  categoryId      String?
  sku             String
  name            String
  description     String?
  unit            String    // PCS | KG | LITRE | BOX | DOZEN
  currentStock    Decimal   @default(0) @db.Decimal(12,3)
  minimumStock    Decimal   @default(0) @db.Decimal(12,3)
  maximumStock    Decimal?  @db.Decimal(12,3)
  reorderPoint    Decimal   @default(0) @db.Decimal(12,3)
  unitCost        Decimal   @default(0) @db.Decimal(10,2)
  totalValue      Decimal   @default(0) @db.Decimal(12,2)
  location        String?
  supplierId      String?
  barcode         String?
  expiryTracking  Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property        Property  @relation(fields: [propertyId], references: [id])
  category        InventoryCategory? @relation(fields: [categoryId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  transactions    InventoryTransaction[]
  purchaseOrderItems POLineItem[]

  @@unique([propertyId, sku])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String    @id @default(cuid())
  itemId          String
  type            String    // STOCK_IN | STOCK_OUT | TRANSFER | ADJUSTMENT | WASTAGE | RETURN
  quantity        Decimal   @db.Decimal(12,3)
  unitCost        Decimal?  @db.Decimal(10,2)
  totalCost       Decimal?  @db.Decimal(12,2)
  referenceId     String?
  referenceType   String?
  expiryDate      DateTime?
  batchNumber     String?
  reason          String?
  notes           String?
  performedBy     String?
  createdAt       DateTime  @default(now())

  item            InventoryItem @relation(fields: [itemId], references: [id])

  @@map("inventory_transactions")
}

// ============================================================
// PROCUREMENT
// ============================================================

model Supplier {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  code            String
  contactName     String?
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  taxId           String?
  bankName        String?
  bankAccount     String?
  paymentTerms    Int       @default(30)
  creditLimit     Decimal?  @db.Decimal(12,2)
  rating          Int?
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inventoryItems  InventoryItem[]
  purchaseOrders  PurchaseOrder[]
  supplierBills   SupplierBill[]
  quotations      Quotation[]

  @@unique([tenantId, code])
  @@map("suppliers")
}

model Quotation {
  id              String    @id @default(cuid())
  tenantId        String
  supplierId      String
  quotationNumber String    @unique
  validUntil      DateTime?
  status          String    @default("PENDING") // PENDING | ACCEPTED | REJECTED | EXPIRED
  totalAmount     Decimal   @db.Decimal(12,2)
  notes           String?
  createdAt       DateTime  @default(now())

  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  items           QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  description   String
  quantity      Decimal   @db.Decimal(12,3)
  unitPrice     Decimal   @db.Decimal(10,2)
  total         Decimal   @db.Decimal(12,2)

  quotation     Quotation @relation(fields: [quotationId], references: [id])

  @@map("quotation_items")
}

model PurchaseRequest {
  id              String            @id @default(cuid())
  tenantId        String
  propertyId      String?
  requestNumber   String            @unique
  requestedById   String?
  status          ProcurementStatus @default(DRAFT)
  urgency         String            @default("NORMAL")
  notes           String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  items           PurchaseRequestItem[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id          String          @id @default(cuid())
  requestId   String
  itemName    String
  quantity    Decimal         @db.Decimal(12,3)
  unit        String
  estimatedCost Decimal?      @db.Decimal(10,2)
  notes       String?

  request     PurchaseRequest @relation(fields: [requestId], references: [id])

  @@map("purchase_request_items")
}

model PurchaseOrder {
  id              String            @id @default(cuid())
  propertyId      String
  supplierId      String
  poNumber        String            @unique
  status          ProcurementStatus @default(DRAFT)
  orderDate       DateTime          @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Decimal           @db.Decimal(12,2)
  taxAmount       Decimal           @default(0) @db.Decimal(12,2)
  shippingCost    Decimal           @default(0) @db.Decimal(10,2)
  totalAmount     Decimal           @db.Decimal(12,2)
  notes           String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  property        Property          @relation(fields: [propertyId], references: [id])
  supplier        Supplier          @relation(fields: [supplierId], references: [id])
  approvedBy      User?             @relation("POApprovedBy", fields: [approvedById], references: [id])
  lineItems       POLineItem[]
  goodsReceipts   GoodsReceipt[]
  supplierBills   SupplierBill[]

  @@map("purchase_orders")
}

model POLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  inventoryItemId String?
  description     String
  quantity        Decimal       @db.Decimal(12,3)
  unitPrice       Decimal       @db.Decimal(10,2)
  taxRate         Decimal       @default(0) @db.Decimal(5,2)
  total           Decimal       @db.Decimal(12,2)
  receivedQty     Decimal       @default(0) @db.Decimal(12,3)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@map("po_line_items")
}

model GoodsReceipt {
  id              String        @id @default(cuid())
  purchaseOrderId String
  receiptNumber   String        @unique
  receivedDate    DateTime      @default(now())
  receivedById    String?
  notes           String?
  createdAt       DateTime      @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items           GoodsReceiptItem[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id            String       @id @default(cuid())
  receiptId     String
  poLineItemId  String?
  description   String
  quantityOrdered Decimal    @db.Decimal(12,3)
  quantityReceived Decimal   @db.Decimal(12,3)
  unitCost      Decimal      @db.Decimal(10,2)
  batchNumber   String?
  expiryDate    DateTime?
  notes         String?

  receipt       GoodsReceipt @relation(fields: [receiptId], references: [id])

  @@map("goods_receipt_items")
}

model SupplierBill {
  id              String     @id @default(cuid())
  tenantId        String
  supplierId      String
  purchaseOrderId String?
  billNumber      String     @unique
  supplierRef     String?
  status          BillStatus @default(DRAFT)
  billDate        DateTime
  dueDate         DateTime
  subtotal        Decimal    @db.Decimal(12,2)
  taxAmount       Decimal    @default(0) @db.Decimal(12,2)
  totalAmount     Decimal    @db.Decimal(12,2)
  paidAmount      Decimal    @default(0) @db.Decimal(12,2)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  supplier        Supplier   @relation(fields: [supplierId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  lineItems       BillLineItem[]
  payments        BillPayment[]

  @@map("supplier_bills")
}

model BillLineItem {
  id          String       @id @default(cuid())
  billId      String
  accountId   String?
  description String
  quantity    Decimal      @db.Decimal(12,3)
  unitPrice   Decimal      @db.Decimal(10,2)
  taxRate     Decimal      @default(0) @db.Decimal(5,2)
  total       Decimal      @db.Decimal(12,2)

  bill        SupplierBill @relation(fields: [billId], references: [id])

  @@map("bill_line_items")
}

model BillPayment {
  id          String       @id @default(cuid())
  billId      String
  amount      Decimal      @db.Decimal(12,2)
  method      PaymentMethod
  reference   String?
  paidAt      DateTime     @default(now())
  notes       String?

  bill        SupplierBill @relation(fields: [billId], references: [id])

  @@map("bill_payments")
}

// ============================================================
// HUMAN RESOURCES
// ============================================================

model Department {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  code        String
  managerId   String?
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  employees   Employee[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Employee {
  id               String         @id @default(cuid())
  userId           String?        @unique
  propertyId       String
  departmentId     String?
  supervisorId     String?
  employeeNumber   String         @unique
  firstName        String
  lastName         String
  preferredName    String?
  email            String?
  phone            String?
  nationalId       String?
  taxId            String?
  dateOfBirth      DateTime?
  gender           String?
  nationality      String?
  address          String?
  emergencyContact String?
  emergencyPhone   String?
  nextOfKin        String?
  nextOfKinPhone   String?
  position         String
  employmentType   String         @default("FULL_TIME") // FULL_TIME | PART_TIME | CONTRACT | CASUAL | TEMPORARY | INTERN | CONSULTANT
  startDate        DateTime
  endDate          DateTime?
  contractEndDate  DateTime?
  probationStartDate DateTime?
  probationEndDate DateTime?
  probationConfirmedAt DateTime?
  status           EmployeeStatus @default(ACTIVE)
  baseSalary       Decimal        @db.Decimal(12,2)
  bankName         String?
  bankAccount      String?
  bankBranch       String?
  mobileMoney      String?
  avatarUrl        String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User?          @relation(fields: [userId], references: [id])
  property         Property       @relation(fields: [propertyId], references: [id])
  department       Department?    @relation(fields: [departmentId], references: [id])
  supervisor       Employee?      @relation("EmployeeSupervisor", fields: [supervisorId], references: [id])
  subordinates     Employee[]     @relation("EmployeeSupervisor")
  attendances      Attendance[]
  attendanceAnomalies AttendanceAnomaly[]
  leaveRequests    LeaveRequest[]
  payrolls         PayrollRecord[]
  payrollDeductions PayrollDeduction[]
  performanceReviews PerformanceReview[]
  probationReviews ProbationReview[]
  disciplinaryCases DisciplinaryCase[]
  suspensions      SuspensionRecord[]
  grievances       GrievanceCase[]
  staffLoans       StaffLoan[]
  assetIssues      EmployeeAssetIssue[]
  shiftRosters     ShiftRoster[]
  trainingAttendances TrainingAttendance[]
  onboardingChecklist OnboardingChecklist?
  offboardingCase  OffboardingCase?
  employeeDocuments EmployeeDocument[]
  cashIncidents    CashHandlingIncident[]
  policyAcknowledgements PolicyAcknowledgement[]
  benefits         EmployeeBenefit[]
  incidents        EmployeeIncident[]

  @@map("employees")
}

model Attendance {
  id           String    @id @default(cuid())
  employeeId   String
  date         DateTime  @db.Date
  clockIn      DateTime?
  clockOut     DateTime?
  hoursWorked  Decimal?  @db.Decimal(5,2)
  status       String    @default("PRESENT") // PRESENT | ABSENT | LATE | HALF_DAY | ON_LEAVE
  notes        String?
  source       String    @default("MANAGER_ENTRY") // SELF_CLOCK | MANAGER_ENTRY
  editHistory  Json?
  recordedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendances")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  leaveType     LeaveType
  status        LeaveStatus @default(PENDING)
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  totalDays     Int
  reason        String?
  approvedById  String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee      Employee    @relation(fields: [employeeId], references: [id])

  @@map("leave_requests")
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  year        Int
  leaveType   LeaveType
  entitled    Int
  taken       Int       @default(0)
  remaining   Int
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, year, leaveType])
  @@map("leave_balances")
}

model PayrollRecord {
  id              String    @id @default(cuid())
  employeeId      String
  periodStart     DateTime  @db.Date
  periodEnd       DateTime  @db.Date
  baseSalary      Decimal   @db.Decimal(12,2)
  allowances      Decimal   @default(0) @db.Decimal(12,2)
  overtime        Decimal   @default(0) @db.Decimal(12,2)
  deductions      Decimal   @default(0) @db.Decimal(12,2)
  tax             Decimal   @default(0) @db.Decimal(12,2)
  netPay          Decimal   @db.Decimal(12,2)
  status          String    @default("DRAFT") // DRAFT | APPROVED | PAID
  paymentMethod   PaymentMethod @default(BANK_TRANSFER)
  paidAt          DateTime?
  notes           String?
  payslipUrl      String?
  createdAt       DateTime  @default(now())

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@map("payroll_records")
}

model PerformanceReview {
  id            String    @id @default(cuid())
  employeeId    String
  reviewerId    String?
  reviewPeriod  String
  reviewType    String    @default("ANNUAL") // PROBATION | MONTHLY | QUARTERLY | ANNUAL
  overallRating Int       // 1-5: 1=Unsatisfactory 2=Needs Improvement 3=Satisfactory 4=Good 5=Excellent
  goals         Json?
  feedback      String?
  improvements  String?
  kpis          Json?
  promotionRecommended Boolean @default(false)
  incrementRecommended Decimal? @db.Decimal(10,2)
  status        String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())

  employee      Employee  @relation(fields: [employeeId], references: [id])

  @@map("performance_reviews")
}

model ProbationReview {
  id               String          @id @default(cuid())
  employeeId       String
  reviewerId       String?
  scheduledDate    DateTime        @db.Date
  conductedAt      DateTime?
  outcome          ProbationOutcome @default(PENDING)
  notes            String?
  supervisorRecommendation String?
  hrRecommendation String?
  finalDecision    String?
  extensionDays    Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  employee         Employee        @relation(fields: [employeeId], references: [id])

  @@map("probation_reviews")
}

// ─── DISCIPLINARY ────────────────────────────────────────────

model DisciplinaryCase {
  id                String                 @id @default(cuid())
  caseNumber        String                 @unique
  employeeId        String
  propertyId        String
  incidentDate      DateTime               @db.Date
  reportedById      String?
  category          String                 // maps to DisciplinaryReason strings
  description       String
  evidence          String[]               @default([])
  witnesses         String?
  investigationNotes String?
  status            DisciplinaryCaseStatus @default(REPORTED)
  decisionDate      DateTime?
  decisionMakerId   String?
  effectiveDate     DateTime?              @db.Date
  appealDeadline    DateTime?              @db.Date
  finalOutcome      String?
  closedAt          DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  employee          Employee               @relation(fields: [employeeId], references: [id])
  actions           DisciplinaryAction[]
  payrollDeductions PayrollDeduction[]
  suspensions       SuspensionRecord[]

  @@map("disciplinary_cases")
}

model DisciplinaryAction {
  id               String                @id @default(cuid())
  caseId           String
  actionType       DisciplinaryActionType
  effectiveDate    DateTime              @db.Date
  endDate          DateTime?             @db.Date
  description      String?
  issuedById       String?
  acknowledgedAt   DateTime?
  createdAt        DateTime              @default(now())

  case             DisciplinaryCase      @relation(fields: [caseId], references: [id])

  @@map("disciplinary_actions")
}

// ─── PAYROLL DEDUCTIONS (CONTROLLED) ─────────────────────────

model PayrollDeduction {
  id               String           @id @default(cuid())
  employeeId       String
  disciplinaryCaseId String?
  staffLoanId      String?
  category         DeductionCategory
  description      String
  amount           Decimal          @db.Decimal(12,2)
  deductionType    String           @default("FIXED") // FIXED | PERCENTAGE
  effectivePeriod  String           // e.g. "2026-06"
  isRecurring      Boolean          @default(false)
  installmentTotal Int?
  installmentPaid  Int              @default(0)
  approvedById     String?
  approvedAt       DateTime?
  status           String           @default("PENDING") // PENDING | APPROVED | APPLIED | REVERSED | WAIVED
  payslipVisible   Boolean          @default(true)
  glAccountCode    String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee         Employee         @relation(fields: [employeeId], references: [id])
  disciplinaryCase DisciplinaryCase? @relation(fields: [disciplinaryCaseId], references: [id])
  staffLoan        StaffLoan?       @relation(fields: [staffLoanId], references: [id])

  @@map("payroll_deductions")
}

// ─── SUSPENSION ──────────────────────────────────────────────

model SuspensionRecord {
  id               String         @id @default(cuid())
  employeeId       String
  disciplinaryCaseId String?
  suspensionType   SuspensionType
  startDate        DateTime       @db.Date
  endDate          DateTime?      @db.Date
  returnDate       DateTime?      @db.Date
  isPaid           Boolean        @default(true)
  reason           String
  approvedById     String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  employee         Employee       @relation(fields: [employeeId], references: [id])
  disciplinaryCase DisciplinaryCase? @relation(fields: [disciplinaryCaseId], references: [id])

  @@map("suspension_records")
}

// ─── GRIEVANCE ───────────────────────────────────────────────

model GrievanceCase {
  id               String          @id @default(cuid())
  caseNumber       String          @unique
  employeeId       String
  propertyId       String
  grievanceType    GrievanceType
  description      String
  status           GrievanceStatus @default(SUBMITTED)
  assignedToId     String?
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  employee         Employee        @relation(fields: [employeeId], references: [id])

  @@map("grievance_cases")
}

// ─── STAFF LOANS / ADVANCES ──────────────────────────────────

model StaffLoan {
  id               String          @id @default(cuid())
  loanNumber       String          @unique
  employeeId       String
  loanType         String          // SALARY_ADVANCE | STAFF_LOAN | EMERGENCY | UNIFORM | DEVICE
  amount           Decimal         @db.Decimal(12,2)
  balance          Decimal         @db.Decimal(12,2)
  interestRate     Decimal         @default(0) @db.Decimal(5,2)
  installmentAmount Decimal        @db.Decimal(12,2)
  installments     Int             @default(1)
  status           StaffLoanStatus @default(PENDING)
  approvedById     String?
  approvedAt       DateTime?
  disbursedAt      DateTime?
  settledAt       DateTime?
  reason           String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  employee         Employee        @relation(fields: [employeeId], references: [id])
  repayments       StaffLoanRepayment[]
  payrollDeductions PayrollDeduction[]

  @@map("staff_loans")
}

model StaffLoanRepayment {
  id          String    @id @default(cuid())
  loanId      String
  amount      Decimal   @db.Decimal(12,2)
  payrollPeriod String?
  method      String    @default("PAYROLL_DEDUCTION")
  notes       String?
  createdAt   DateTime  @default(now())

  loan        StaffLoan @relation(fields: [loanId], references: [id])

  @@map("staff_loan_repayments")
}

// ─── ASSET / UNIFORM ISSUANCE ────────────────────────────────

model EmployeeAssetIssue {
  id               String   @id @default(cuid())
  employeeId       String
  assetType        String   // UNIFORM | KEY | ACCESS_CARD | RADIO | POS_DEVICE | LAPTOP | PHONE | ID_CARD | TOOL | OTHER
  description      String
  serialNumber     String?
  issuedDate       DateTime @db.Date
  issuedById       String?
  expectedReturn   DateTime? @db.Date
  returnedDate     DateTime? @db.Date
  conditionOnIssue String   @default("GOOD") // GOOD | FAIR | DAMAGED
  conditionOnReturn String?
  replacementCost  Decimal? @db.Decimal(10,2)
  status           String   @default("ISSUED") // ISSUED | RETURNED | LOST | DAMAGED
  recoveryDeductionId String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee         Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_asset_issues")
}

// ─── ATTENDANCE ANOMALY ───────────────────────────────────────

model AttendanceAnomaly {
  id            String                @id @default(cuid())
  employeeId    String
  anomalyType   AttendanceAnomalyType
  date          DateTime              @db.Date
  description   String
  severity      String                @default("LOW") // LOW | MEDIUM | HIGH
  status        String                @default("OPEN") // OPEN | REVIEWED | ESCALATED | DISMISSED | LINKED_TO_CASE
  reviewedById  String?
  reviewNotes   String?
  linkedCaseId  String?
  createdAt     DateTime              @default(now())

  employee      Employee              @relation(fields: [employeeId], references: [id])

  @@map("attendance_anomalies")
}

// ─── SHIFT & ROSTER ──────────────────────────────────────────

model ShiftRoster {
  id           String    @id @default(cuid())
  employeeId   String
  propertyId   String
  shiftDate    DateTime  @db.Date
  shiftType    String    @default("MORNING")
  startTime    String?   // HH:MM
  endTime      String?   // HH:MM
  breakMinutes Int       @default(0)
  isConfirmed  Boolean   @default(false)
  swapRequestedWith String?
  swapApproved Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, shiftDate])
  @@map("shift_rosters")
}

model ShiftTypeConfig {
  id           String   @id @default(cuid())
  propertyId   String
  name         String
  label        String
  startTime    String
  endTime      String
  breakMinutes Int      @default(0)
  color        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, name])
  @@map("shift_type_configs")
}

// ─── TRAINING ────────────────────────────────────────────────

model TrainingProgram {
  id           String   @id @default(cuid())
  propertyId   String
  title        String
  description  String?
  category     String   // SOP | SAFETY | COMPLIANCE | SKILLS | ORIENTATION | OTHER
  requiredFor  String[] @default([]) // roles that must complete
  durationHours Decimal? @db.Decimal(5,2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  attendances  TrainingAttendance[]

  @@map("training_programs")
}

model TrainingAttendance {
  id          String           @id @default(cuid())
  programId   String
  employeeId  String
  scheduledAt DateTime
  completedAt DateTime?
  score       Decimal?         @db.Decimal(5,2)
  passed      Boolean?
  notes       String?
  certUrl     String?
  createdAt   DateTime         @default(now())

  program     TrainingProgram  @relation(fields: [programId], references: [id])
  employee    Employee         @relation(fields: [employeeId], references: [id])

  @@map("training_attendances")
}

// ─── RECRUITMENT ─────────────────────────────────────────────

model RecruitmentJobOpening {
  id           String      @id @default(cuid())
  propertyId   String
  title        String
  departmentId String?
  description  String?
  requirements String?
  salaryMin    Decimal?    @db.Decimal(12,2)
  salaryMax    Decimal?    @db.Decimal(12,2)
  openDate     DateTime    @db.Date
  closeDate    DateTime?   @db.Date
  status       String      @default("OPEN") // OPEN | FILLED | CANCELLED | ON_HOLD
  hiringManagerId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  candidates   Candidate[]

  @@map("recruitment_job_openings")
}

model Candidate {
  id           String          @id @default(cuid())
  jobOpeningId String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  appliedAt    DateTime        @default(now())
  notes        String?
  offerSalary  Decimal?        @db.Decimal(12,2)
  hiredAsEmployeeId String?
  updatedAt    DateTime        @updatedAt

  jobOpening   RecruitmentJobOpening @relation(fields: [jobOpeningId], references: [id])
  interviews   CandidateInterview[]

  @@map("candidates")
}

model CandidateInterview {
  id           String    @id @default(cuid())
  candidateId  String
  scheduledAt  DateTime
  interviewerId String?
  format       String    @default("IN_PERSON") // IN_PERSON | PHONE | VIDEO
  score        Decimal?  @db.Decimal(5,2)
  notes        String?
  outcome      String?   // PROCEED | REJECT | ON_HOLD
  createdAt    DateTime  @default(now())

  candidate    Candidate @relation(fields: [candidateId], references: [id])

  @@map("candidate_interviews")
}

// ─── ONBOARDING ──────────────────────────────────────────────

model OnboardingChecklist {
  id                  String          @id @default(cuid())
  employeeId          String          @unique
  status              OnboardingStatus @default(PENDING)
  contractUploaded    Boolean         @default(false)
  idCaptured          Boolean         @default(false)
  roleAssigned        Boolean         @default(false)
  payrollCreated      Boolean         @default(false)
  deptAssigned        Boolean         @default(false)
  uniformIssued       Boolean         @default(false)
  systemAccess        Boolean         @default(false)
  orientationDone     Boolean         @default(false)
  policyAcknowledged  Boolean         @default(false)
  completedAt         DateTime?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  employee            Employee        @relation(fields: [employeeId], references: [id])

  @@map("onboarding_checklists")
}

// ─── OFFBOARDING ─────────────────────────────────────────────

model OffboardingCase {
  id                  String        @id @default(cuid())
  employeeId          String        @unique
  separationType      SeparationType
  noticeDate          DateTime?     @db.Date
  lastWorkingDate     DateTime?     @db.Date
  letterUploaded      Boolean       @default(false)
  finalPayProcessed   Boolean       @default(false)
  deductionsSettled   Boolean       @default(false)
  handoverCompleted   Boolean       @default(false)
  assetsReturned      Boolean       @default(false)
  accessRevoked       Boolean       @default(false)
  exitInterviewDone   Boolean       @default(false)
  finalDocumentsIssued Boolean      @default(false)
  status              String        @default("OPEN") // OPEN | COMPLETED
  notes               String?
  processedById       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  employee            Employee      @relation(fields: [employeeId], references: [id])

  @@map("offboarding_cases")
}

// ─── EMPLOYEE DOCUMENTS ───────────────────────────────────────

model EmployeeDocument {
  id           String   @id @default(cuid())
  employeeId   String
  category     String   // CONTRACT | WARNING | SUSPENSION | APPRAISAL | ID | CERT | PAYROLL | LEAVE | GRIEVANCE | MEDICAL | OTHER
  title        String
  fileUrl      String
  expiryDate   DateTime? @db.Date
  uploadedById String?
  notes        String?
  createdAt    DateTime @default(now())

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_documents")
}

// ─── POLICY DOCUMENTS & ACKNOWLEDGEMENTS ─────────────────────

model PolicyDocument {
  id           String   @id @default(cuid())
  propertyId   String
  title        String
  category     String   // CODE_OF_CONDUCT | CASH_HANDLING | GUEST_PRIVACY | DISCIPLINARY | ATTENDANCE | ANTI_HARASSMENT | SAFETY | IT_USAGE | OTHER
  version      String   @default("1.0")
  content      String?
  fileUrl      String?
  isActive     Boolean  @default(true)
  effectiveDate DateTime @db.Date
  createdAt    DateTime @default(now())

  acknowledgements PolicyAcknowledgement[]

  @@map("policy_documents")
}

model PolicyAcknowledgement {
  id          String         @id @default(cuid())
  policyId    String
  employeeId  String
  acknowledgedAt DateTime    @default(now())
  notes       String?

  policy      PolicyDocument @relation(fields: [policyId], references: [id])
  employee    Employee       @relation(fields: [employeeId], references: [id])

  @@unique([policyId, employeeId])
  @@map("policy_acknowledgements")
}

// ─── CASH HANDLING INCIDENTS ──────────────────────────────────

model CashHandlingIncident {
  id              String   @id @default(cuid())
  employeeId      String
  propertyId      String
  incidentType    String   // SHORTAGE | TILL_VARIANCE | REFUND_ABUSE | VOID | RATE_OVERRIDE | SETTLEMENT_DISCREPANCY
  amount          Decimal? @db.Decimal(12,2)
  description     String
  incidentDate    DateTime @db.Date
  reportedById    String?
  disciplinaryCaseId String?
  recoveryDeductionId String?
  status          String   @default("OPEN") // OPEN | REVIEWED | LINKED | RESOLVED
  notes           String?
  createdAt       DateTime @default(now())

  employee        Employee @relation(fields: [employeeId], references: [id])

  @@map("cash_handling_incidents")
}

// ─── EMPLOYEE BENEFITS ────────────────────────────────────────

model EmployeeBenefit {
  id           String   @id @default(cuid())
  employeeId   String
  benefitType  String   // HOUSING | TRANSPORT | MEAL | PHONE | MEDICAL | RISK | UNIFORM | STAFF_DISCOUNT
  description  String?
  amount       Decimal  @db.Decimal(10,2)
  frequency    String   @default("MONTHLY") // MONTHLY | ANNUAL | ONE_TIME
  isActive     Boolean  @default(true)
  startDate    DateTime @db.Date
  endDate      DateTime? @db.Date
  createdAt    DateTime @default(now())

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_benefits")
}

// ─── EMPLOYEE INCIDENTS (HEALTH & SAFETY) ────────────────────

model EmployeeIncident {
  id           String   @id @default(cuid())
  employeeId   String
  propertyId   String
  incidentType String   // INJURY | ACCIDENT | SAFETY_VIOLATION | MEDICAL | SECURITY | GUEST_CONFLICT
  description  String
  incidentDate DateTime @db.Date
  location     String?
  witnesses    String?
  evidenceUrls String[] @default([])
  followUpActions String?
  returnToWorkDate DateTime? @db.Date
  reportedById String?
  status       String   @default("OPEN") // OPEN | UNDER_REVIEW | RESOLVED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_incidents")
}

// ─── HR APPROVAL REQUESTS ─────────────────────────────────────

model HRApprovalRequest {
  id           String   @id @default(cuid())
  propertyId   String
  requestType  String   // DEDUCTION | SUSPENSION | SALARY_CHANGE | TERMINATION | LOAN | LEAVE_OVERRIDE | ASSET_RECOVERY | PROBATION
  referenceId  String   // ID of the linked record
  requestedById String
  assignedToId String?
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  notes        String?
  decidedAt    DateTime?
  createdAt    DateTime @default(now())

  @@map("hr_approval_requests")
}

// ============================================================
// MAINTENANCE MANAGEMENT
// ============================================================

model Asset {
  id              String      @id @default(cuid())
  propertyId      String
  assetNumber     String      @unique
  name            String
  category        String      // AC | GENERATOR | FURNITURE | ELECTRONICS | PLUMBING | OTHER
  brand           String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchasePrice   Decimal?    @db.Decimal(12,2)
  currentValue    Decimal?    @db.Decimal(12,2)
  location        String?
  status          AssetStatus @default(ACTIVE)
  warrantyExpiry  DateTime?
  lastServiced    DateTime?
  nextServiceDate DateTime?
  notes           String?
  imageUrl        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  property        Property    @relation(fields: [propertyId], references: [id])
  workOrders      WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]

  @@map("assets")
}

model WorkOrder {
  id              String              @id @default(cuid())
  assetId         String?
  roomId          String?
  tenantId        String
  workOrderNumber String              @unique
  title           String
  description     String
  status          MaintenanceStatus   @default(PENDING)
  priority        MaintenancePriority @default(MEDIUM)
  assignedToId    String?
  reportedById    String?
  scheduledDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  estimatedHours  Decimal?            @db.Decimal(5,2)
  actualHours     Decimal?            @db.Decimal(5,2)
  laborCost       Decimal?            @db.Decimal(10,2)
  partsCost       Decimal?            @db.Decimal(10,2)
  totalCost       Decimal?            @db.Decimal(10,2)
  resolution      String?
  notes           String?
  images          String[]            @default([])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  asset           Asset?              @relation(fields: [assetId], references: [id])
  room            Room?               @relation(fields: [roomId], references: [id])

  @@map("work_orders")
}

model MaintenanceSchedule {
  id              String    @id @default(cuid())
  assetId         String
  title           String
  description     String?
  frequency       String    // DAILY | WEEKLY | MONTHLY | QUARTERLY | ANNUAL
  lastPerformed   DateTime?
  nextDueDate     DateTime
  estimatedCost   Decimal?  @db.Decimal(10,2)
  assignedToId    String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  asset           Asset     @relation(fields: [assetId], references: [id])

  @@map("maintenance_schedules")
}

// ============================================================
// ACCOUNTING SYSTEM (XERO-STYLE)
// ============================================================

model Account {
  id              String      @id @default(cuid())
  propertyId      String
  code            String
  name            String
  type            AccountType
  parentId        String?
  description     String?
  isSystem        Boolean     @default(false)
  isActive        Boolean     @default(true)
  normalBalance   TransactionType @default(DEBIT)
  currentBalance  Decimal     @default(0) @db.Decimal(15,2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  property        Property    @relation(fields: [propertyId], references: [id])
  parent          Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]   @relation("AccountHierarchy")
  journalLines    JournalLine[]

  @@unique([propertyId, code])
  @@map("accounts")
}

model JournalEntry {
  id              String             @id @default(cuid())
  tenantId        String
  entryNumber     String             @unique
  status          JournalEntryStatus @default(DRAFT)
  date            DateTime           @db.Date
  description     String
  reference       String?
  referenceType   String?
  createdById     String?
  postedAt        DateTime?
  voidedAt        DateTime?
  voidReason      String?
  totalDebit      Decimal            @db.Decimal(15,2)
  totalCredit     Decimal            @db.Decimal(15,2)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  createdBy       User?              @relation("JournalCreatedBy", fields: [createdById], references: [id])
  lines           JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id              String       @id @default(cuid())
  journalEntryId  String
  accountId       String
  type            TransactionType
  amount          Decimal      @db.Decimal(15,2)
  description     String?
  currency        String       @default("USD")

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  account         Account      @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

model BankAccount {
  id              String    @id @default(cuid())
  propertyId      String
  accountId       String?
  bankName        String
  accountName     String
  accountNumber   String
  routingNumber   String?
  swiftCode       String?
  currency        String    @default("USD")
  currentBalance  Decimal   @default(0) @db.Decimal(15,2)
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property        Property  @relation(fields: [propertyId], references: [id])
  reconciliations BankReconciliation[]
  transactions    BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id              String      @id @default(cuid())
  bankAccountId   String
  date            DateTime    @db.Date
  description     String
  amount          Decimal     @db.Decimal(15,2)
  type            TransactionType
  reference       String?
  isReconciled    Boolean     @default(false)
  reconciledAt    DateTime?
  journalEntryId  String?
  createdAt       DateTime    @default(now())

  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("bank_transactions")
}

model BankReconciliation {
  id              String      @id @default(cuid())
  bankAccountId   String
  statementDate   DateTime    @db.Date
  openingBalance  Decimal     @db.Decimal(15,2)
  closingBalance  Decimal     @db.Decimal(15,2)
  reconciledBalance Decimal   @db.Decimal(15,2)
  difference      Decimal     @default(0) @db.Decimal(15,2)
  status          String      @default("IN_PROGRESS")
  completedAt     DateTime?
  createdAt       DateTime    @default(now())

  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("bank_reconciliations")
}

model Budget {
  id              String       @id @default(cuid())
  propertyId      String
  name            String
  period          BudgetPeriod
  startDate       DateTime     @db.Date
  endDate         DateTime     @db.Date
  status          String       @default("DRAFT")
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  property        Property     @relation(fields: [propertyId], references: [id])
  lines           BudgetLine[]

  @@map("budgets")
}

model BudgetLine {
  id          String    @id @default(cuid())
  budgetId    String
  accountId   String?
  accountName String
  month       Int?
  amount      Decimal   @db.Decimal(15,2)
  actual      Decimal   @default(0) @db.Decimal(15,2)
  variance    Decimal   @default(0) @db.Decimal(15,2)

  budget      Budget    @relation(fields: [budgetId], references: [id])

  @@map("budget_lines")
}

model TaxRate {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  code        String
  rate        Decimal   @db.Decimal(5,2)
  type        String    // GST | VAT | WITHHOLDING | SALES | OTHER
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([tenantId, code])
  @@map("tax_rates")
}

// ============================================================
// DOCUMENT MANAGEMENT
// ============================================================

model Document {
  id              String           @id @default(cuid())
  propertyId      String?
  tenantId        String
  name            String
  description     String?
  category        DocumentCategory
  customCategory  String?
  fileUrl         String
  fileName        String
  fileSize        Int
  mimeType        String
  version         Int              @default(1)
  tags            String[]         @default([])
  uploadedById    String?
  isPublic        Boolean          @default(false)
  expiryDate      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  property        Property?        @relation(fields: [propertyId], references: [id])
  versions        DocumentVersion[]

  @@map("documents")
}

model DocumentCustomCategory {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  color      String   @default("slate")
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, name])
  @@map("document_custom_categories")
}

model DocumentVersion {
  id          String    @id @default(cuid())
  documentId  String
  version     Int
  fileUrl     String
  fileName    String
  fileSize    Int
  notes       String?
  uploadedById String?
  createdAt   DateTime  @default(now())

  document    Document  @relation(fields: [documentId], references: [id])

  @@map("document_versions")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  description String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  title       String
  body        String
  type        String    // INFO | WARNING | ERROR | SUCCESS
  channel     String    // IN_APP | EMAIL | SMS | WHATSAPP
  isRead      Boolean   @default(false)
  readAt      DateTime?
  referenceId String?
  referenceType String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, userId])
  @@map("notifications")
}

model ReportSchedule {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  reportType  String
  frequency   String    // DAILY | WEEKLY | MONTHLY
  recipients  String[]
  channels    String[]  @default(["EMAIL"])
  parameters  Json?
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("report_schedules")
}

// ============================================================
// NIGHT AUDIT
// ============================================================

model NightAudit {
  id              String   @id @default(cuid())
  propertyId      String
  auditDate       DateTime
  status          String   @default("OPEN")  // OPEN | IN_PROGRESS | CLOSED | REOPENED
  totalRevenue    Decimal  @db.Decimal(12,2) @default(0)
  totalPayments   Decimal  @db.Decimal(12,2) @default(0)
  occupancyRate   Decimal  @db.Decimal(5,2)  @default(0)
  roomsOccupied   Int      @default(0)
  roomsAvailable  Int      @default(0)
  newArrivals     Int      @default(0)
  departures      Int      @default(0)
  noShows         Int      @default(0)
  cashOnHand      Decimal  @db.Decimal(12,2) @default(0)
  discrepancies   Json?
  runBy           String?
  closedAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, auditDate])
  @@map("night_audits")
}

// ============================================================
// PRIVACY & AUDIT LOGS
// ============================================================

model GuestPrivacyLog {
  id         String   @id @default(cuid())
  guestId    String
  viewedBy   String
  viewedAt   DateTime @default(now())
  reason     String?
  ipAddress  String?
  action     String   // VIEW_IDENTITY | EDIT_IDENTITY | EXPORT

  guest      Guest    @relation(fields: [guestId], references: [id])

  @@map("guest_privacy_logs")
}
